<% if flash[:notice] %>
  <div style="display: flex; align-items: center; gap: 12px; background: var(--cw-panel); border: 1px solid var(--cw-line); border-left: 3px solid var(--cw-green); border-radius: 8px; padding: 10px 14px; margin-bottom: 20px; font-size: 13px;">
    <svg width="14" height="14" viewBox="0 0 16 16" style="flex-shrink: 0; color: var(--cw-green);">
      <path d="M3 8l3 3 7-8" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div style="flex: 1; color: var(--cw-ink);"><%= flash[:notice] %></div>
  </div>
<% end %>

<% if flash[:alert] %>
  <div style="display: flex; align-items: center; gap: 12px; background: var(--cw-panel); border: 1px solid var(--cw-line); border-left: 3px solid var(--cw-amber); border-radius: 8px; padding: 10px 14px; margin-bottom: 20px; font-size: 13px;">
    <svg width="14" height="14" viewBox="0 0 16 16" style="flex-shrink: 0; color: var(--cw-amber);">
      <path d="M8 2v7M8 12v.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
      <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" fill="none"/>
    </svg>
    <div style="flex: 1; color: var(--cw-ink);"><%= flash[:alert] %></div>
  </div>
<% end %>
