  .cw-form-hint { font-size: 12px; color: var(--cw-muted); margin-top: 6px; }
  .cw-form-error { font-size: 12px; color: #b02a2a; margin-top: 6px; }
  .cw-form-check { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--cw-ink); cursor: pointer; }
  .cw-form-check input[type="checkbox"] {
