  .cw-btn-sm { padding: 6px 14px; font-size: 13px; }
  .cw-btn-default { background: var(--cw-paper); color: var(--cw-ink); border-color: var(--cw-line2); }
  .cw-btn-default:hover { background: rgba(20,20,16,0.04); }
  .cw-btn-primary { background: var(--cw-ink); color: var(--cw-paper); }
  .cw-btn-primary:hover { background: #000; }
  .cw-btn-accent { background: var(--cw-accent); color: var(--cw-paper); }
  .cw-btn-accent:hover { filter: brightness(1.05); }
  .cw-btn-danger { background: transparent; color: #b02a2a; border-color: rgba(176,42,42,0.35); }
