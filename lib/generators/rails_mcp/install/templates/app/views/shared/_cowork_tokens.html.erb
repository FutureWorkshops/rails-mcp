  .cw-account-menu { position: absolute; top: 100%; left: 0; margin-top: 6px; background: var(--cw-paper); border: 1px solid var(--cw-line2); border-radius: 8px; padding: 4px; min-width: 200px; z-index: 100; box-shadow: 0 8px 20px rgba(20,20,16,0.08); }
  .cw-account-menu-item { padding: 7px 10px; border-radius: 6px; font-size: 13px; color: var(--cw-ink); display: block; width: 100%; text-align: left; background: transparent; border: none; cursor: pointer; font-family: inherit; }
