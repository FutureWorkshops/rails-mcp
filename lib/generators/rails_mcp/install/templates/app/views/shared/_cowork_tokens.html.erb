  }
  html, body { background: var(--cw-paper); color: var(--cw-ink); font-family: "Inter Tight", system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  ::selection { background: var(--cw-accent); color: var(--cw-paper); }
