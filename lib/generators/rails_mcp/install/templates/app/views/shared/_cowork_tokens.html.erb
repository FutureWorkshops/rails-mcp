  .cw-account-menu-divider { height: 1px; background: var(--cw-line); margin: 4px 0; }

  .cw-text-btn {
    display: inline-flex; align-items: center; gap: 4px;
    background: transparent; border: none; padding: 0; cursor: pointer;
    font-family: inherit; font-size: 13px; color: var(--cw-muted);
    transition: color .15s;
  }
  .cw-text-btn:hover { color: var(--cw-ink); }

  .cw-todo-check {
    margin-top: 1px; flex-shrink: 0; background: transparent; border: none; padding: 0;
    cursor: pointer;
  }
  .cw-todo-check span {
    width: 18px; height: 18px; border-radius: 4px;
    border: 1px solid var(--cw-line2); display: inline-block;
    transition: border-color .15s;
  }
  .cw-todo-check:hover span { border-color: var(--cw-ink); }

  .cw-banner-btn {
    background: var(--cw-paper); color: var(--cw-ink); border: none; border-radius: 6px;
    padding: 6px 14px; font-size: 13px; font-weight: 500; cursor: pointer;
    white-space: nowrap; font-family: inherit;
    transition: background-color .15s, box-shadow .15s;
  }
  .cw-banner-btn:hover {
    background: #fffaf0;
    box-shadow: 0 1px 2px rgba(20,20,16,0.18);
  }
</style>
