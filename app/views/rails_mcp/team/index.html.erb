<% content_for :title, "Team" %>

<div style="margin-bottom: 24px;">
  <h1 class="cw-page-title">Team</h1>
  <p class="cw-page-lede">Manage the people who can use this <%= RailsMcp.config.display_name %> workspace.</p>
</div>

<div style="display: grid; gap: 16px;">
  <section class="cw-panel" style="padding: 24px;">
    <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 14px;">Workspace name</h2>
    <%= form_with url: RailsMcp::Engine.routes.url_helpers.team_update_account_path,
                  method: :patch, local: true,
                  data: { turbo: false } do |f| %>
      <div style="display: flex; gap: 8px; align-items: center;">
        <%= f.text_field :name, value: @account.name, required: true,
              class: "cw-form-input", style: "flex: 1;" %>
        <%= f.submit "Save", class: "cw-btn cw-btn-default" %>
      </div>
    <% end %>
  </section>

  <section class="cw-panel" style="padding: 24px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0;">Members</h2>
      <span class="cw-label-mono"><%= @members.size %></span>
    </div>
    <ul style="list-style: none; padding: 0; margin: 0; border: 1px solid var(--cw-line); border-radius: 8px; overflow: hidden;">
      <% @members.each_with_index do |m, i| %>
        <li style="padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; <%= 'border-top: 1px solid var(--cw-line);' unless i.zero? %>">
          <div>
            <div style="font-size: 14px; font-weight: 600;">
              <%= m.name.presence || m.email %>
              <% if m == current_user %><span class="cw-pill cw-pill-default" style="margin-left: 6px;">you</span><% end %>
            </div>
            <div style="font-size: 12px; color: var(--cw-muted); margin-top: 2px;"><%= m.email %></div>
          </div>
          <span class="cw-form-hint">Joined <%= m.created_at.strftime("%-d %b %Y") %></span>
        </li>
      <% end %>
    </ul>
  </section>

  <section class="cw-panel" style="padding: 24px;">
    <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 14px;">Invite a teammate</h2>
    <%= form_with url: RailsMcp::Engine.routes.url_helpers.team_invitations_path,
                  method: :post, local: true do |f| %>
      <div style="display: flex; gap: 8px; align-items: center;">
        <%= f.email_field :email, required: true, placeholder: "person@example.com",
              class: "cw-form-input", style: "flex: 1;" %>
        <%= f.submit "Send invite", class: "cw-btn cw-btn-accent" %>
      </div>
    <% end %>
    <p class="cw-form-hint" style="margin-top: 10px;">
      Invites expire after <%= RailsMcp::Invitation::EXPIRY_WINDOW.inspect %>.
    </p>
  </section>

  <section class="cw-panel" style="padding: 24px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0;">Pending invitations</h2>
      <span class="cw-label-mono"><%= @invitations.size %></span>
    </div>
    <% if @invitations.empty? %>
      <p style="padding: 24px; text-align: center; color: var(--cw-muted); font-size: 13px; border: 1px solid var(--cw-line); border-radius: 8px; margin: 0;">
        No outstanding invites.
      </p>
    <% else %>
      <ul style="list-style: none; padding: 0; margin: 0; border: 1px solid var(--cw-line); border-radius: 8px; overflow: hidden;">
        <% @invitations.each_with_index do |inv, i| %>
          <li style="padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; <%= 'border-top: 1px solid var(--cw-line);' unless i.zero? %>">
            <div>
              <div style="font-size: 14px; font-weight: 600;"><%= inv.email %></div>
              <div style="font-size: 12px; color: var(--cw-muted); margin-top: 2px;">
                Invited by <%= inv.invited_by&.email %> · expires <%= inv.expires_at.strftime("%-d %b %Y") %>
              </div>
            </div>
            <%= button_to "Revoke",
                  RailsMcp::Engine.routes.url_helpers.team_invitation_path(inv),
                  method: :delete,
                  form: { data: { turbo_confirm: "Revoke this invite?" } },
                  class: "cw-btn cw-btn-danger cw-btn-sm" %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
</div>
