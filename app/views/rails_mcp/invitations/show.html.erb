<% content_for :title, "Team invite" %>

<div style="max-width: 480px; margin: 48px auto 0;">
  <div class="cw-panel" style="padding: 28px; display: grid; gap: 16px;">
    <% case @state %>
    <% when :claimable %>
      <h1 class="cw-page-title" style="font-size: 22px;">You're invited</h1>
      <p style="font-size: 14px; color: var(--cw-ink); line-height: 1.6;">
        <strong><%= @invitation.invited_by&.name.presence || @invitation.invited_by&.email %></strong>
        has invited <strong><%= @invitation.email %></strong> to join
        <strong><%= @invitation.account.name %></strong> on <%= RailsMcp.config.display_name %>.
      </p>
      <p class="cw-form-hint">
        Sign in with the account associated with <strong><%= @invitation.email %></strong> to accept.
      </p>
      <%= link_to "Sign in to accept", RailsMcp.config.sign_in_path.call(request),
            class: "cw-btn cw-btn-accent",
            style: "width: 100%; justify-content: center;" %>

    <% when :accepted %>
      <h1 class="cw-page-title" style="font-size: 22px;">Already accepted</h1>
      <p style="font-size: 14px; color: var(--cw-ink); line-height: 1.6;">
        This invite was already claimed on
        <%= @invitation.accepted_at.strftime("%-d %b %Y") %>.
        <% if @invitation.invited_by %>If that wasn't you, contact <%= @invitation.invited_by.email %>.<% end %>
      </p>

    <% when :revoked %>
      <h1 class="cw-page-title" style="font-size: 22px;">Invite revoked</h1>
      <p style="font-size: 14px; color: var(--cw-ink); line-height: 1.6;">
        This invite was cancelled<% if @invitation.invited_by %> by <%= @invitation.invited_by.email %><% end %>.
        Ask them to send you a new one.
      </p>

    <% when :expired %>
      <h1 class="cw-page-title" style="font-size: 22px;">Invite expired</h1>
      <p style="font-size: 14px; color: var(--cw-ink); line-height: 1.6;">
        This invite expired on <%= @invitation.expires_at.strftime("%-d %b %Y") %>.
        <% if @invitation.invited_by %>Ask <%= @invitation.invited_by.email %> to send a new one.<% end %>
      </p>

    <% else %>
      <h1 class="cw-page-title" style="font-size: 22px;">Invite not found</h1>
      <p style="font-size: 14px; color: var(--cw-ink); line-height: 1.6;">
        We couldn't find an invite with that link. Double-check the URL or ask the sender for a new invitation.
      </p>
    <% end %>
  </div>
</div>
