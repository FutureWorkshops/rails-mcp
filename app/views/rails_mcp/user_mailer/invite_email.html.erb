<table width="100%" cellpadding="0" cellspacing="0" style="background: #f5f5f5; padding: 24px 0;">
  <tr>
    <td align="center">
      <table width="520" cellpadding="0" cellspacing="0" style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #111827;">
        <tr>
          <td style="padding: 32px;">
            <h1 style="margin: 0 0 12px; font-size: 20px;">You're invited to <%= @account_name %></h1>
            <p style="margin: 0 0 16px; font-size: 14px; color: #4b5563;">
              <strong><%= @inviter_name %></strong> invited <strong><%= @invitation.email %></strong>
              to join the <strong><%= @account_name %></strong> workspace on <%= @app_name %>.
            </p>

            <p style="margin: 24px 0;">
              <a href="<%= @accept_url %>"
                 style="background: #2563eb; color: white; text-decoration: none; padding: 12px 18px; border-radius: 8px; font-weight: 600; font-size: 14px; display: inline-block;">
                Accept invitation
              </a>
            </p>

            <p style="margin: 0 0 8px; font-size: 12px; color: #6b7280;">
              Or paste this link into your browser:
            </p>
            <p style="margin: 0 0 16px; font-size: 12px; color: #6b7280; word-break: break-all;">
              <%= @accept_url %>
            </p>
            <p style="margin: 0; font-size: 12px; color: #9ca3af;">
              This invitation expires on <%= @invitation.expires_at.strftime("%-d %b %Y") %>.
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
