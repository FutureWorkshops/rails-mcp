<% content_for :title, "Welcome" %>

<div style="max-width: 480px; margin: 48px auto 0;">
  <div style="margin-bottom: 24px; text-align: center;">
    <h1 class="cw-page-title">Name your workspace</h1>
    <p class="cw-page-lede">Pick a short name for your team. You can change it later.</p>
  </div>

  <div class="cw-panel" style="padding: 24px;">
    <%= form_with url: RailsMcp::Engine.routes.url_helpers.onboarding_path,
                  method: :post,
                  local: true do |f| %>
      <div class="cw-form-field">
        <%= f.label :name, "Workspace name", class: "cw-form-label" %>
        <%= f.text_field :name, value: @default_name, required: true, class: "cw-form-input" %>
        <% if @default_name.present? %>
          <p class="cw-form-hint">Suggested: <%= @default_name %></p>
        <% end %>
      </div>
      <%= f.submit "Continue",
            class: "cw-btn cw-btn-accent",
            style: "width: 100%; justify-content: center;" %>
    <% end %>
  </div>
</div>
